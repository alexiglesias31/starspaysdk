# StarsPay SDK Playwright validation harness — environment template.
# Copy to .env.live and fill in. Mock-mode runs need NO env vars at all.

# ── Live mode toggle ──────────────────────────────────────────────────────
# Set to "1" to route Telegram Bot API calls to api.telegram.org instead of
# the in-process mock. Without this, every journey runs against mocks.
STARSPAY_LIVE=

# ── Telegram MTProto (required only when STARSPAY_LIVE=1) ─────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USE_TEST_DC=1
TELEGRAM_PHONE=
TELEGRAM_SESSION_STRING=

# ── Bot + provider tokens (live mode only) ────────────────────────────────
TEST_BOT_TOKEN=
TEST_BOT_USERNAME=
TELEGRAM_PAYMENTS_TEST_TOKEN=

# ── Harness wiring (defaults are fine for local runs) ─────────────────────
HARNESS_BASE_URL=http://127.0.0.1:5179
SDK_SERVER_PORT=4173
